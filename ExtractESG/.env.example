# Qiniu AI model API
QINIU_API_KEY=
QINIU_BASE_URL=https://api.qnaigc.com/v1
QINIU_DEFAULT_TIMEOUT_SECONDS=120

# Optional explicit model pins. Leave empty to let QiniuModelRegistry select by capability.
EXTRACT_ESG_TEXT_MODEL=
EXTRACT_ESG_VISION_MODEL=
EXTRACT_ESG_REASONING_MODEL=
EXTRACT_ESG_FAST_MODEL=

# Runtime
EXTRACT_ESG_ENV=local
EXTRACT_ESG_OBJECT_STORE=./.local/artifacts
EXTRACT_ESG_MODEL_CACHE=./.local/qiniu_models.json
EXTRACT_ESG_SQLITE_DB=./.local/extract_esg.db
